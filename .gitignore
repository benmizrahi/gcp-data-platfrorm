# ==============================================================================
# OS & General
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~
*.swp
*.swo

# ==============================================================================
# IDEs & Editors
# ==============================================================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ==============================================================================
# Go (Golang)
# ==============================================================================
# Compiled test binaries
*.test
*.out

# Go Workspace file
go.work

# Common tool binaries
bin/

# Dependency directories (if using vendoring)
vendor/

# ==============================================================================
# Terraform
# ==============================================================================
# Local .terraform directory
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data like passwords or private keys
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# ==============================================================================
# Protobuf & Buf (Generated Code)
# ==============================================================================
# Exclude generated code and assets to keep repository clean
**/gen/
